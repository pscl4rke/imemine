
cache-file "/autofs/photometa/newsboat_cache.db"

# Note: script uses `setsid -f` so when newsboat exits the window isn't killed:
#browser "/home/psc/imemine/bin/open-in-browser-bg -u urltube %u"
browser "/home/psc/imemine/bin/open-in-browser-bg %u"

# The default keybinding is not documented anywhere properly.  Refer to:
#   https://github.com/newsboat/newsboat/blob/master/src/keymap.cpp

# really dangerous
unbind-key A
unbind-key D
unbind-key ^D
unbind-key $

bind-key SPACE pagedown

# Was "next-feed" and "prev-feed"...
#   (also "next" and "prev" didn't play nice either)
bind-key j down
bind-key k up
goto-next-feed no

# No "limit" mechanism
bind-key / open-search
bind-key l open-search

# Was "sort" and "rev-sort"...
bind-key g home
bind-key G end

datetime-format "%a %_d %b %Y"
articlelist-format "%4i %f | %D | %?T?|%-17T| ?%t"

# look into "cleanup-on-quit no"

prepopulate-query-feeds yes

history-limit 0
