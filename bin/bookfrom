#!/usr/bin/env tmpmake
# vim:ft=make:

# Do not delete "intermediate" files
#	THIS BREAKS TAB COMPLETION
#.SECONDARY:
#	But for some reason this is fine???
.NOTINTERMEDIATE:

.DEFAULT: ALL

sources := $(wildcard *.url)
internals := $(subst url,internal,$(sources))
title := $(shell cat meta.title)
author := $(shell cat meta.author)
slug != echo "$(title) $(author)" | slugify
final := $(slug)_converted.kepub.epub

ALL:
	@echo "CHECKING METADATA..."
	test "$(title)"
	test "$(author)"
	@echo "CHECKING SOURCES..."
	test -e sources
	mkdir -p images
	$(MAKE) urls
	$(MAKE) $(final)

# Use "magick -list font" for options. This comes from APT's "fonts-urw-base35"
coverfont := AvantGarde-Book

frontcover.jpeg: meta.title meta.author
	magick \
		-size 700x1000 \
		-background white \
		-fill black \
		-gravity center \
		-pointsize 48 \
		-font "$(coverfont)" \
		label:"$(title)\n$(author)" \
		$@

$(slug).epub: frontcover.jpeg $(internals)
	@echo "CHECKING METADATA..."
	test "$(title)"
	test "$(author)"
	@echo "BUILDING $@..."
	pandoc -f html -t epub3 -o $@ \
		--number-sections \
		--metadata=title:"$(title)" \
		--metadata=author:"$(author)" \
		--epub-title-page=false \
		--epub-cover-image=frontcover.jpeg \
		$(internals)

# --toc     <-- pointless because pandoc will only detect <h1> when
#               directly inside <body> tag, not in a <div>

%_converted.kepub.epub: %.epub
	kepubify $^

#%.raw: %.url
#	@echo "FETCHING $@..."
#	wget "$$(cat $^)" -O $@.tmp
#	#wget "$$(cat $^)" -r -l 1 -A jpeg,jpg,png,gif,bmp -nd -P images -O $@.tmp
#	mv $@.tmp $@

# In case it's not obvious... "external" refers to docs with <img> that link
# to external web resources, and "internal" is where we've downloaded locally.
# Unfortunately some webmasters block pandoc from pulling images!

%.external: %.url
	@echo "FETCHING $@..."
	readable -l force "$$(cat $^)" > $@.tmp
	mv $@.tmp $@

%.internal: %.external
	@echo "FETCHING IMAGES FOR $@..."
	localimg $^ $@.tmp images
	mv $@.tmp $@


urls: sources
	@echo Only touching *.url timestamps if the content has changed...
	cat $^ | nl -n rz -w 2 | while read number url; do \
		echo "$$url" > "tmp.url" ;\
		if diff "$$number.url" "tmp.url"; then \
			rm "tmp.url" ;\
		else \
			mv "tmp.url" "$$number.url" ;\
		fi ;\
	done

copy-to-ereader: $(final)
	cp -aiv $^ /media/*/*eReader/bookfrom/.

copy-to-nas: $(slug).epub $(final)
	cp -aiv $^ /autofs/nas/*Ebooks/.
